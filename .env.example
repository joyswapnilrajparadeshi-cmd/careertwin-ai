# CareerTwin AI local development configuration
# Copy this file to .env and replace the placeholders.

PORT=8787

# Groq AI engine
GROQ_API_KEY=your_groq_api_key
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-8b-instant
AI_PROVIDER=Groq

# Optional OpenAI-compatible variable names are also supported:
# OPENAI_API_KEY=your_groq_api_key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-8b-instant

# Supabase Auth + database
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_PLANS_TABLE=career_plans
DEFAULT_USER_ROLE=student
ALLOW_PUBLIC_ADMIN_SIGNUP=false
